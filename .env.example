# HTTP server
QUS_HTTP_PORT=8080

# OpenSearch
QUS_OPENSEARCH_URL=http://localhost:9200
QUS_OPENSEARCH_USERNAME=
QUS_OPENSEARCH_PASSWORD=
QUS_OPENSEARCH_INDEX=concepts

# OpenTelemetry
QUS_OTEL_ENABLED=false
QUS_OTEL_EXPORTER_ADDR=localhost:4317
QUS_OTEL_SERVICE_NAME=qus

# Domain config directory
QUS_CONFIG_DIR=configs

# LLM (hybrid v2 pipeline — AWS Bedrock)
QUS_LLM_ENABLED=false
QUS_LLM_REGION=eu-west-1
QUS_LLM_MODEL=eu.amazon.nova-lite-v1:0
QUS_LLM_MAX_RETRIES=1
QUS_LLM_MIN_CONFIDENCE=0.65
QUS_LLM_FAIL_OPEN=true

# Logging
LOG_LEVEL=info
